# Previous mock API base URL:
# VITE_API_BASE_URL=http://127.0.0.1:4523/m1/7931435-7683186-default
# In local dev, leave this empty and use the Vite `/bqi` proxy.
# VITE_API_BASE_URL=http://192.168.2.4:8000
VITE_API_DEVICE=background
VITE_USE_MOCK_DATA=false
VITE_MOCK_DATA_SCOPES=
VITE_API_TOKEN=
VITE_API_TOKEN_HEADER=Authorization
VITE_API_TOKEN_PREFIX=

# 高德地图（https://console.amap.com/ 申请，并配置安全域名 Referer 白名单）
# 若控制台开启「Key + 安全密钥」，需同时配置两项（建议复制到 .env.local，勿提交密钥）
# VITE_AMAP_KEY=
# VITE_AMAP_SECURITY_JS_CODE=
